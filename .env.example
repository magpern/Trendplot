OPENAI_API_KEY=sk-your-openai-api-key
# =========================================================
# OpenAI Provider
# =========================================================

OPENAI_PROVIDER_NAME=openai
OPENAI_REQUEST_TIMEOUT_SECONDS=180

# Legacy fallback only.
# Not used for task routing when tiered routing is enabled.
OPENAI_MODEL=gpt-5-mini

# =========================================================
# Tiered Model Routing
# =========================================================

# Lightweight / cheap tasks
# - cleanup
# - classification
# - category lookup
# - extraction
OPENAI_LIGHT_MODEL=gpt-5-nano

# Standard reasoning/content tasks
# - website analysis
# - YouTube evaluation
# - SEO metadata
# - backlink planning
# - FAQ generation
# - social posts
OPENAI_STANDARD_MODEL=gpt-5-mini

# Premium editorial/review tasks
# - article generation
# - section expansion
# - humanization
# - sanity review
# - biomedical review
OPENAI_PREMIUM_MODEL=gpt-5

# =========================================================
# Output Token Budgets
# =========================================================

OPENAI_MAX_OUTPUT_TOKENS_LIGHT=2000
OPENAI_MAX_OUTPUT_TOKENS_STANDARD=4000
OPENAI_MAX_OUTPUT_TOKENS_PREMIUM=12000
OPENAI_MAX_OUTPUT_TOKENS_ARTICLE_GENERATION=16000
OPENAI_MAX_OUTPUT_TOKENS_ARTICLE_REPAIR=16000
OPENAI_MAX_OUTPUT_TOKENS_SECTION_EXPANSION=8000
OPENAI_MAX_OUTPUT_TOKENS_HUMANIZATION=16000
# Website analysis uses a compact crawl digest for downstream ideation.
OPENAI_MAX_OUTPUT_TOKENS_WEBSITE_ANALYSIS=8000
# Do not retry on timeout — retries resend the full prompt and burn input tokens.
OPENAI_WEBSITE_ANALYSIS_MAX_RETRIES=0
WEBSITE_ANALYSIS_DIGEST_MAX_PAGES=40

# =========================================================
# Global Reasoning Defaults
# =========================================================

# Global fallback only.
# Per-tier and per-task overrides below take precedence.
OPENAI_ENABLE_REASONING=false
OPENAI_REASONING_EFFORT=medium

# =========================================================
# Tier-Level Reasoning Policies
# =========================================================

# LIGHT tier
OPENAI_LIGHT_REASONING_ENABLED=false
OPENAI_LIGHT_REASONING_EFFORT=low

# STANDARD tier
OPENAI_STANDARD_REASONING_ENABLED=false
OPENAI_STANDARD_REASONING_EFFORT=low

# PREMIUM tier
OPENAI_PREMIUM_REASONING_ENABLED=true
OPENAI_PREMIUM_REASONING_EFFORT=medium

# =========================================================
# Task-Specific Reasoning Overrides
# =========================================================

# Editorial generation
OPENAI_REASONING_ARTICLE_GENERATION=medium

# Deep expansion/refinement
OPENAI_REASONING_SECTION_EXPANSION=high

# Quality/editorial review
OPENAI_REASONING_QUALITY_REVIEW=medium

# Compliance/safety review
OPENAI_REASONING_SANITY_REVIEW=high
OPENAI_REASONING_BIOMEDICAL_REVIEW=high

# Final wording cleanup
OPENAI_REASONING_HUMANIZATION=medium

# Website analysis — keep off for faster JSON (digest + AI ideation downstream)
OPENAI_REASONING_WEBSITE_ANALYSIS=off

# =========================================================
# Recommended Future Overrides (optional)
# =========================================================

# OPENAI_REASONING_ARTICLE_REPAIR=medium
# OPENAI_REASONING_FAQ_GENERATION=low
# OPENAI_REASONING_YOUTUBE_EVALUATION=low
# OPENAI_REASONING_BACKLINK_PLANNING=low
# OPENAI_REASONING_SOCIAL_POST_GENERATION=low
# OPENAI_REASONING_SEO_METADATA=low

# =========================================================
# Notes
# =========================================================

# Reasoning priority:
# task override
# -> tier config
# -> global config
# -> disabled

# High reasoning is intentionally limited to:
# - section expansion
# - sanity review
# - biomedical review

# Lightweight tasks intentionally avoid reasoning
# to reduce latency and token cost.

# Quality/sanity/publishing gates remain enforced
# regardless of reasoning configuration.

YOUTUBE_API_KEY=your-youtube-data-api-key

# SQLite local development:
DATABASE_URL=sqlite:///./data/seo_content_worker.db
# PostgreSQL Docker/production:
# DATABASE_URL=postgresql+psycopg://seo_user:seo_password@postgres:5432/seo_worker


WORDPRESS_DEFAULT_TEMPLATE=elementor_full_width
WORDPRESS_DEFAULT_CATEGORY_ID=
WORDPRESS_DEFAULT_CATEGORY_SLUG=
WORDPRESS_DEFAULT_TAGS=
WORDPRESS_AUTO_CREATE_TAGS=true
WORDPRESS_MAX_TAGS=8
WORDPRESS_ALLOW_ELEMENTOR_CANVAS=false
WORDPRESS_REQUIRE_FEATURED_IMAGE=false
WORDPRESS_UPLOAD_FEATURED_IMAGE=false
WORDPRESS_FAIL_ON_TEMPLATE_ERROR=false
# Trendplot Connector plugin (Phase 1) — HMAC auth via shared secret + site ID
WORDPRESS_CONNECTOR_ENABLED=false
# Default upload target when not set per workspace: staging | production
WORDPRESS_CONNECTOR_ACTIVE_ENVIRONMENT=staging
# Legacy single-server fallback (treated as staging if staging vars are empty)
WORDPRESS_CONNECTOR_BASE_URL=
WORDPRESS_CONNECTOR_SITE_ID=
WORDPRESS_CONNECTOR_SECRET=
# Optional per-environment defaults (workspace UI settings override these)
WORDPRESS_CONNECTOR_STAGING_BASE_URL=
WORDPRESS_CONNECTOR_STAGING_SITE_ID=
WORDPRESS_CONNECTOR_STAGING_SECRET=
WORDPRESS_CONNECTOR_PRODUCTION_BASE_URL=
WORDPRESS_CONNECTOR_PRODUCTION_SITE_ID=
WORDPRESS_CONNECTOR_PRODUCTION_SECRET=
WORDPRESS_CONNECTOR_TIMEOUT_SECONDS=30

DEFAULT_PUBLISH_POLICY=manual_review
PUBLISH_POLICY=manual_review
ALLOW_LIVE_PUBLISH=false
ALLOW_AUTO_LIVE=false
UNATTENDED_MODE_ENABLED=false
UNATTENDED_DEFAULT_PUBLISH_POLICY=auto_draft
UNATTENDED_ALLOW_AUTO_LIVE=false
UNATTENDED_REQUIRE_QUALITY_PASS=true
UNATTENDED_REQUIRE_SANITY_PASS=true
HUMAN_REVIEW_REQUIRED=true
AUTOPILOT_ENABLED=true
AUTOPILOT_DEFAULT_MODE=manual_review
AUTOPUBLISH_CADENCE=weekly
CONTENT_PLAN_HORIZON_DAYS=30
MAX_AUTOPILOT_JOBS_PER_DAY=1
MAX_PAGES_PER_SITE=30
CRAWL_SMALL_SITE_FULL_THRESHOLD=50
CRAWL_LARGE_SITE_SAMPLE_LIMIT=100
CRAWL_CONCURRENCY_PER_DOMAIN=4
CRAWL_REQUEST_TIMEOUT_SECONDS=15
CRAWL_RETRY_COUNT=1
CRAWL_RETRY_BACKOFF_SECONDS=2
CRAWL_POLITENESS_DELAY_MS=250
SITEMAP_DISCOVERY_ENABLED=true
CRAWL_FALLBACK_ENABLED=true
SITEMAP_MAX_URLS_TO_PARSE=5000
SITEMAP_MAX_SITEMAPS_TO_PARSE=50
REASSESSMENT_ENABLED=true
REASSESSMENT_INTERVAL_DAYS=7
MAX_REPAIR_PASSES=1
TARGET_MIN_WORD_COUNT=1800
MAX_SECTION_EXPANSION_PASSES=2
MAX_SECTIONS_EXPANDED_PER_PASS=5
TARGET_SECTION_MIN_WORDS=250
TARGET_ARTICLE_MIN_WORDS=1800
HUMANIZATION_REWRITE_STRENGTH=editorial_rewrite
# Simplified article pipeline (default): Brief → generation → deterministic validation → publish
SIMPLIFIED_ARTICLE_PIPELINE=true
ENABLE_ARTICLE_HUMANIZATION=false
ENABLE_NARRATIVE_EDITOR=false
ENABLE_SEMANTIC_SANITY_REVIEW=false
ENABLE_SECTION_EXPANSION=false
ENABLE_YOUTUBE_AI_EVALUATION=false
PROMPT_TEMPLATE_DIR=app/prompts/templates
ALLOW_PROMPT_FALLBACK=false
PROMPT_STRICT_MODE=true
ENABLE_JSONLD_SCHEMA=true
# publishable = reader-facing HTML (default); editorial_full = includes verification blocks
ARTICLE_DEFAULT_RENDER_SURFACE=publishable
OPPORTUNITY_VERTICAL=auto
ENABLE_EXTERNAL_RESEARCH=true
EXTERNAL_RESEARCH_MAX_QUERIES=20
EXTERNAL_RESEARCH_MAX_RESULTS_PER_QUERY=5
ENABLE_ACADEMIC_RESEARCH=false
ENABLE_REDDIT_RESEARCH=false

# =========================================================
# Crawl, niche, and AI ideation (product analyze path)
# =========================================================

NICHE_INTELLIGENCE_ENABLED=true
AI_OPPORTUNITY_IDEATION_ENABLED=true
AI_OPPORTUNITY_IDEATION_MODEL=
AI_OPPORTUNITY_IDEATION_MIN_IDEAS=40
AI_OPPORTUNITY_IDEATION_MAX_IDEAS=75
AI_OPPORTUNITY_IDEATION_TEMPERATURE=0.3
AI_OPPORTUNITY_IDEATION_TIMEOUT_SECONDS=240
AI_OPPORTUNITY_IDEATION_INCLUDE_SITEMAP=true
AI_OPPORTUNITY_IDEATION_CACHE_ENABLED=false
AI_OPPORTUNITY_IDEATION_CACHE_TTL_HOURS=24
AI_OPPORTUNITY_IDEATION_MAX_OUTPUT_TOKENS=16384
AI_OPPORTUNITY_IDEATION_BATCH_SIZE=30
AI_OPPORTUNITY_IDEATION_MAX_TOP_UP_ROUNDS=3
ENABLE_AI_IMAGE_GENERATION=false
AI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_STYLE=clean editorial
AI_IMAGE_VARIANTS_PER_PLACEMENT=1
AI_IMAGE_MAX_IMAGES=3
AI_IMAGE_PLAN_INLINE_IMAGES=true
AI_IMAGE_MAX_INLINE_IMAGE_PLACEMENTS=2
AI_IMAGE_ENABLE_VERTICAL_RULES=true
AI_IMAGE_GENERATE_FEATURED=true
AI_IMAGE_OUTPUT_DIR=data/generated-images

# Optional vertical-specific safety settings.
# RESEARCH_USE_DISCLAIMER_URL=
# BIOMEDICAL_RUO_DISCLAIMER=For research use only. Not intended for human consumption, therapeutic, or diagnostic use.

LOG_LEVEL=INFO
